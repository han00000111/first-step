generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ContextType {
  mobile
  pc
  offline
  unknown
}

enum ReminderStyle {
  gentle
  minimal_action
  ddl_push
}

enum TaskStatus {
  active
  archived
}

enum ReminderEventType {
  reminder_sent
  accept
  delay
  reject
}

enum ReminderResponseType {
  now_start
  remind_later
  not_today
}

enum FirstStepRecommendationSource {
  llm
  rule_fallback
}

enum FirstStepRecommendationEventType {
  generated
  shown
  accepted
  regenerated
}

model Task {
  id                            String                         @id @default(cuid())
  content                       String
  parsedAction                  String
  dueAt                         DateTime?
  contextType                   ContextType                    @default(unknown)
  reminderStyle                 ReminderStyle                  @default(minimal_action)
  status                        TaskStatus                     @default(active)
  nextReminderAt                DateTime?
  archivedAt                    DateTime?
  createdAt                     DateTime                       @default(now())
  updatedAt                     DateTime                       @updatedAt
  reminderEvents                ReminderEvent[]
  firstStepRecommendations      FirstStepRecommendation[]
  firstStepRecommendationEvents FirstStepRecommendationEvent[]

  @@index([status, nextReminderAt])
  @@index([dueAt])
}

model ReminderEvent {
  id           String               @id @default(cuid())
  taskId       String
  eventType    ReminderEventType
  responseType ReminderResponseType?
  messageShown String
  scheduledFor DateTime?
  happenedAt   DateTime             @default(now())
  delayMinutes Int?
  task         Task                 @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, happenedAt])
  @@index([eventType, happenedAt])
}

model DevicePushSubscription {
  id         String   @id @default(cuid())
  endpoint   String   @unique
  p256dh     String
  auth       String
  userAgent  String?
  platform   String?
  isActive   Boolean  @default(true)
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isActive, updatedAt])
}

model FirstStepRecommendation {
  id                     String                        @id @default(cuid())
  taskId                 String
  scheduledFor           DateTime
  reminderStage          String
  preferredTone          String
  delayCount             Int                           @default(0)
  source                 FirstStepRecommendationSource
  modelName              String?
  canDoNow               Boolean
  frictionSource         String
  decompositionType      String
  recommendedFirstStep   String
  whyThisStep            String
  isSmallerThanOriginal  Boolean
  confidence             Float
  requestPayload         Json?
  rawResponse            Json?
  generationError        String?
  createdAt              DateTime                      @default(now())
  task                   Task                          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  recommendationEvents   FirstStepRecommendationEvent[]

  @@index([taskId, scheduledFor, createdAt])
  @@index([source, createdAt])
}

model FirstStepRecommendationEvent {
  id               String                           @id @default(cuid())
  recommendationId String
  taskId           String
  eventType        FirstStepRecommendationEventType
  metadata         Json?
  createdAt        DateTime                         @default(now())
  recommendation   FirstStepRecommendation          @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  task             Task                             @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([recommendationId, eventType, createdAt])
  @@index([taskId, eventType, createdAt])
}
